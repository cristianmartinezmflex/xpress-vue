{
  "tabs": [
    {
      "title": "Sync",
      "sections": [
        {
          "title": "Sync Operations",
          "columns": [
            {
              "controls": [
                {
                  "id": "sync_buttons",
                  "type": "button_bar",
                  "buttons": [
                    {
                      "id": "btn_partial_sync",
                      "title": "Partial Sync Now",
                      "onClick": "dm_shared_runPartialSync",
                      "tooltip": "Pull the latest table changes from the external system. Partial syncs are incremental changes to Users and Badges, if allowed by the external system's API."
                    },
                    {
                      "id": "btn_full_sync",
                      "title": "Full Sync Now",
                      "onClick": "dm_shared_runFullSync",
                      "tooltip": "Pull all records from the external system. Replaces the full local dataset with the current state of the external system."
                    },
                    {
                      "id": "btn_custom_sync",
                      "title": "Custom Sync Now",
                      "onClick": "dm_shared_runCustomSync",
                      "tooltip": "Run a custom sync operation defined by this data manager. Right-click to edit the custom sync tables.",
                      "rightClickMenu": [
                        { "label": "Edit Custom Sync", "onClick": "dm_shared_editCustomSync" }
                      ]
                    }
                  ]
                },
                {
                  "id": "sync_log",
                  "type": "log_view"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "title": "Basic",
      "sections": [
        {
          "title": "Sync Type",
          "columns": [
            {
              "controls": [
                {
                  "id": "sync_type",
                  "type": "radio",
                  "title": "",
                  "values": [
                    { "text": "OpenAccess", "value": "OpenAccess" },
                    { "text": "DataConduit", "value": "DataConduit" }
                  ],
                  "default": "OpenAccess"
                },
                {
                  "id": "remote_name",
                  "type": "text",
                  "title": "Remote Computer Name",
                  "default": "onguard83.ad.telaeris.com"
                },
                {
                  "id": "user",
                  "type": "text",
                  "title": "Username",
                  "default": "nathaniel"
                },
                {
                  "id": "password",
                  "type": "password",
                  "title": "Password",
                  "default": ""
                },
                {
                  "id": "enable_data_protect",
                  "type": "boolean",
                  "title": "Enable Data Protect",
                  "default": false
                }
              ]
            }
          ]
        },
        {
          "title": "DataConduit",
          "enable": "sync_type == 'DataConduit'",
          "columns": [
            {
              "controls": [
                {
                  "id": "use_login",
                  "type": "boolean",
                  "title": "Use DataConduit Explicit Login",
                  "default": false
                },
                {
                  "id": "remote_namespace",
                  "type": "text",
                  "title": "Remote Computer Namespace (DataConduit Only)",
                  "default": "root\\onguard"
                },
                {
                  "id": "namespace",
                  "type": "text",
                  "title": "Full Namespace",
                  "default": ""
                },
                {
                  "id": "large_user_table",
                  "type": "boolean",
                  "title": "Large User Data Set",
                  "default": false
                },
                {
                  "id": "large_data_step_size",
                  "type": "number_spinner",
                  "title": "Large Data Step Size",
                  "default": 20000,
                  "validations": [
                    { "type": "min_max", "min": 1, "max": 999999, "error": "Must be between 1 and 999999" }
                  ],
                  "enable": "large_user_table == true"
                },
                {
                  "id": "large_data_failure_count",
                  "type": "number_spinner",
                  "title": "Large Data Failure Count",
                  "default": 3,
                  "validations": [
                    { "type": "min_max", "min": 0, "max": 100, "error": "Must be between 0 and 100" }
                  ],
                  "enable": "large_user_table == true"
                }
              ]
            }
          ]
        },
        {
          "title": "Open Access",
          "enable": "sync_type == 'OpenAccess'",
          "columns": [
            {
              "controls": [
                {
                  "id": "page_size",
                  "type": "number_spinner",
                  "title": "Page Size",
                  "default": 100,
                  "validations": [
                    { "type": "required", "error": "Required" },
                    { "type": "min_max", "min": 1, "max": 10000, "error": "Must be between 1 and 10000" }
                  ]
                },
                {
                  "id": "thread_count",
                  "type": "number_spinner",
                  "title": "Thread Size",
                  "default": 5,
                  "validations": [
                    { "type": "required", "error": "Required" },
                    { "type": "min_max", "min": 1, "max": 64, "error": "Must be between 1 and 64" }
                  ]
                },
                {
                  "id": "check_heartbeat",
                  "type": "boolean",
                  "title": "Check Heartbeat",
                  "default": true
                },
                {
                  "id": "picture_query_size",
                  "type": "number_spinner",
                  "title": "Picture Query Size",
                  "default": 100,
                  "validations": [
                    { "type": "min_max", "min": 1, "max": 10000, "error": "Must be between 1 and 10000" }
                  ]
                },
                {
                  "id": "open_access_port",
                  "type": "number_spinner",
                  "title": "Port",
                  "default": 8080,
                  "validations": [
                    { "type": "required", "error": "Required" },
                    { "type": "min_max", "min": 1, "max": 65535, "error": "Must be between 1 and 65535" }
                  ]
                },
                {
                  "id": "open_access_directory_name",
                  "type": "select",
                  "title": "Directory",
                  "values": [
                    { "text": "AD.TELAERIS.COM", "value": "AD.TELAERIS.COM" },
                    { "text": "WORKGROUP", "value": "WORKGROUP" },
                    { "text": "LOCAL", "value": "LOCAL" }
                  ],
                  "default": "AD.TELAERIS.COM"
                },
                {
                  "id": "legacy_api",
                  "type": "boolean",
                  "title": "Legacy API",
                  "default": false
                },
                {
                  "id": "trace_software_events_openaccess",
                  "type": "boolean",
                  "title": "Trace Software Events",
                  "default": false
                },
                {
                  "id": "request_timeout",
                  "type": "number_spinner",
                  "title": "Request Timeout (Seconds)",
                  "default": 30,
                  "validations": [
                    { "type": "min_max", "min": 1, "max": 300, "error": "Must be between 1 and 300" }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "Open Access Subscription",
          "columns": [
            {
              "controls": [
                {
                  "id": "subscription_description",
                  "type": "text",
                  "title": "Default Subscription Description",
                  "default": "XPressEntry Watcher"
                },
                {
                  "id": "btn_bar_subscription",
                  "type": "button_bar",
                  "buttons": [
                    { "id": "btn_check_subscriptions", "title": "Check XPressEntry Subscriptions", "onClick": "checkSubscriptions" },
                    { "id": "btn_delete_subscription", "title": "Delete Current Subscription", "onClick": "deleteSubscription" }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "Software Events",
          "columns": [
            {
              "controls": [
                { "id": "software_events", "type": "boolean", "title": "Subscribe to Software Events", "default": true },
                { "id": "activity_software_events", "type": "boolean", "title": "Enable Activity Software Events", "default": true },
                { "id": "badge_and_person_software_events", "type": "boolean", "title": "Enable Badge and Person Software Events", "default": true },
                { "id": "delete_software_events_upon_processing", "type": "boolean", "title": "Delete Software Events Upon Processing", "default": true },
                {
                  "id": "async_event_handling",
                  "type": "boolean",
                  "title": "Asynchronous Event Handling",
                  "default": false,
                  "enable": "sync_type == 'DataConduit'"
                },
                {
                  "id": "days_between_software_event_cleanup",
                  "type": "number_spinner",
                  "title": "Days Before Software Event Removal",
                  "default": 1,
                  "validations": [
                    { "type": "min_max", "min": 0, "max": 365, "error": "Must be between 0 and 365" }
                  ],
                  "enable": "delete_software_events_upon_processing == false"
                },
                {
                  "id": "software_event_retry_count",
                  "type": "number_spinner",
                  "title": "Retry Count",
                  "default": 3,
                  "validations": [
                    { "type": "min_max", "min": 0, "max": 99, "error": "Must be between 0 and 99" }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "Activity / Occupancy",
          "columns": [
            {
              "controls": [
                { "id": "get_activities", "type": "boolean", "title": "Download OnGuard Activities", "default": false },
                { "id": "ignore_last_dm_sync_hours", "type": "boolean", "title": "Ignore Last DM Sync Hours", "default": false },
                {
                  "id": "download_activity_timer",
                  "type": "number_spinner",
                  "title": "Download Activity # Hours",
                  "default": 16,
                  "validations": [
                    { "type": "min_max", "min": 1, "max": 720, "error": "Must be between 1 and 720" }
                  ]
                },
                { "id": "get_occupancies", "type": "boolean", "title": "Download OnGuard Occupancy", "default": true },
                { "id": "ignore_empty_area", "type": "boolean", "title": "Ignore Empty Reader Area", "default": true },
                { "id": "onguard_hazard_safe_areas", "type": "boolean", "title": "Use OnGuard Hazard/Safe Areas", "default": true },
                { "id": "dont_send_access_grant_or_deny", "type": "boolean", "title": "Don't Send Access Grant Or Deny", "default": false },
                { "id": "subscribe_to_soft_apb_events", "type": "boolean", "title": "Subscribe to Soft APB Events", "default": false },
                { "id": "access_denied_events", "type": "boolean", "title": "Subscribe to Access Denied Events", "default": false },
                { "id": "send_activities_via_device_translator", "type": "boolean", "title": "Send Activities via Device Translator", "default": false }
              ]
            }
          ]
        },
        {
          "title": "Cardholders / Visitors",
          "columns": [
            {
              "controls": [
                { "id": "cardholders_no_visitors", "type": "boolean", "title": "Cardholders Only. No Visitors", "default": false },
                { "id": "sync_user_phone_no", "type": "boolean", "title": "Sync User Phone Number", "default": false },
                { "id": "sync_user_email", "type": "boolean", "title": "Sync User Email", "default": false },
                { "id": "sync_employee_id", "type": "boolean", "title": "Sync Employee ID", "default": true },
                { "id": "badge_deactivation", "type": "boolean", "title": "Deactivate Badges by Date/Time", "default": true },
                { "id": "only_cardholders_with_badges", "type": "boolean", "title": "Filter Cardholders with Active Badges", "default": false },
                { "id": "filter_active_cardholders", "type": "boolean", "title": "Filter Cardholders by Expired Date", "default": false },
                {
                  "id": "filter_active_cardholders_days",
                  "type": "number_spinner",
                  "title": "Pull users with Expired Date Within",
                  "default": 365,
                  "validations": [
                    { "type": "min_max", "min": 0, "max": 9999, "error": "Must be between 0 and 9999" }
                  ],
                  "enable": "filter_active_cardholders == true"
                },
                {
                  "id": "filter_apply_visitors",
                  "type": "boolean",
                  "title": "Apply Filter to Visitors",
                  "default": false,
                  "enable": "cardholders_no_visitors == false"
                }
              ]
            }
          ]
        },
        {
          "title": "",
          "columns": [
            {
              "controls": [
                {
                  "id": "btn_bar_basic",
                  "type": "button_bar",
                  "buttons": [
                    { "id": "btn_test_connect", "title": "Test Connect", "onClick": "dm_shared_testConnection" },
                    { "id": "btn_defaults", "title": "Defaults", "onClick": "setDefaults" },
                    { "id": "btn_ok", "title": "OK", "onClick": "dm_shared_save" }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "title": "Advanced",
      "sections": [
        {
          "title": "Visitors",
          "columns": [
            {
              "controls": [
                { "id": "send_visitors", "type": "boolean", "title": "Send XPressEntry Visitors to OnGuard", "default": false },
                { "id": "visitor_id_field", "type": "text", "title": "Visitor ID Field", "default": "" },
                { "id": "visitor_company_field", "type": "text", "title": "Visitor Company Field", "default": "" },
                { "id": "visit_host_id", "type": "text", "title": "Visit Default Host Cardholder ID", "default": "" }
              ]
            }
          ]
        },
        {
          "title": "Watch List",
          "columns": [
            {
              "controls": [
                { "id": "watch_list_field", "type": "text", "title": "Watch List Field", "default": "" },
                { "id": "watch_list_table", "type": "text", "title": "Watch List Table", "default": "" }
              ]
            }
          ]
        },
        {
          "title": "Login Activity",
          "columns": [
            {
              "controls": [
                { "id": "send_login_activities", "type": "boolean", "title": "Send Login Activities as DataConduit Events", "default": false },
                { "id": "dataconduit_source_name", "type": "text", "title": "DataConduIT Source", "default": "" },
                { "id": "dataconduit_door_prefix", "type": "text", "title": "DataConduIT Prefix for Door", "default": "" }
              ]
            }
          ]
        },
        {
          "title": "Segments",
          "columns": [
            {
              "controls": [
                { "id": "segments_list", "type": "text", "title": "Segments", "default": "" },
                {
                  "id": "btn_bar_segments",
                  "type": "button_bar",
                  "buttons": [
                    { "id": "btn_update_segment_list", "title": "Update Segment list", "onClick": "updateSegmentList" }
                  ]
                },
                { "id": "cardholder_segment", "type": "boolean", "title": "Segment Cardholders", "default": false },
                { "id": "reader_segment", "type": "boolean", "title": "Segment Readers", "default": false },
                { "id": "visitor_segment", "type": "boolean", "title": "Segment Visitors", "default": false },
                { "id": "accesslevel_segment", "type": "boolean", "title": "Segment Access Levels", "default": false }
              ]
            }
          ]
        },
        {
          "title": "Fingerprint",
          "columns": [
            {
              "controls": [
                { "id": "sync_fingerprints_from_onguard", "type": "boolean", "title": "Sync Fingerprints from OnGuard", "default": false },
                { "id": "fingerprint_type_ids", "type": "text", "title": "Fingerprint Type IDs", "default": "" }
              ]
            }
          ]
        },
        {
          "title": "Companies",
          "columns": [
            {
              "controls": [
                { "id": "companies_custom_list", "type": "text", "title": "Companies Custom List", "default": "" },
                { "id": "companies_custom_ref", "type": "text", "title": "Companies Custom Ref", "default": "" },
                { "id": "department", "type": "text", "title": "Department", "default": "DEPT" }
              ]
            }
          ]
        },
        {
          "title": "General",
          "columns": [
            {
              "controls": [
                { "id": "enable_occupancy_debug", "type": "boolean", "title": "Enable Occupancy Debug", "default": false },
                { "id": "enable_record_deletion", "type": "boolean", "title": "Enable Record Deletion", "default": true },
                {
                  "id": "safety_delete_threshold",
                  "type": "number_spinner",
                  "title": "Safety Delete Threshold",
                  "default": 0,
                  "validations": [
                    { "type": "min_max", "min": 0, "max": 9999, "error": "Must be between 0 and 9999" }
                  ]
                },
                { "id": "badge_invalid_override", "type": "text", "title": "Badge Invalid Override", "default": "" }
              ]
            }
          ]
        },
        {
          "title": "Badge Types",
          "columns": [
            {
              "controls": [
                { "id": "badge_type_employee", "type": "boolean", "title": "Employee", "default": false },
                { "id": "badge_type_visitor", "type": "boolean", "title": "Visitor", "default": false },
                { "id": "badge_type_temporary", "type": "boolean", "title": "Temporary", "default": false },
                { "id": "badge_type_vehicle", "type": "boolean", "title": "Vehicle", "default": false },
                { "id": "exclude_selected_badges", "type": "boolean", "title": "Exclude Selected Badges", "default": false }
              ]
            }
          ]
        },
        {
          "title": "Alarm Activity",
          "columns": [
            {
              "controls": [
                { "id": "alarm_logical_source_name", "type": "text", "title": "Logical Source Name", "default": "" },
                { "id": "logical_device_prefix_for_reader", "type": "text", "title": "Logical Device Prefix for Reader", "default": "" },
                {
                  "id": "btn_bar_alarm",
                  "type": "button_bar",
                  "buttons": [
                    { "id": "btn_create_logical_source", "title": "Create Logical Source and Readers", "onClick": "createLogicalSource" }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "Custom Access Level Assignments",
          "columns": [
            {
              "controls": [
                { "id": "enable_assignments_by_training_status", "type": "boolean", "title": "Enable Assignments by Training Status", "default": false }
              ]
            }
          ]
        },
        {
          "title": "Panel Filter (Readers)",
          "columns": [
            {
              "controls": [
                { "id": "panel_placeholder_panel", "type": "boolean", "title": "PLACEHOLDER PANEL", "default": false },
                { "id": "panel_newtestp", "type": "boolean", "title": "NEWTESTP", "default": false },
                { "id": "panel_xpressentry", "type": "boolean", "title": "XPressEntry", "default": false },
                { "id": "panel_xpe", "type": "boolean", "title": "XPE", "default": false },
                { "id": "panel_ivanxpressentry", "type": "boolean", "title": "IvanXPressEntry", "default": false },
                { "id": "panel_xpe_commsvr2", "type": "boolean", "title": "XPE-COMMSVR2", "default": false },
                {
                  "id": "btn_bar_panel",
                  "type": "button_bar",
                  "buttons": [
                    { "id": "btn_update_panel_list", "title": "Update Panel List", "onClick": "updatePanelList" }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "User Gender Sync",
          "columns": [
            {
              "controls": [
                { "id": "enable_user_gender_mappings", "type": "boolean", "title": "Enable User Gender Sync", "default": false },
                { "id": "gender_field", "type": "text", "title": "User Gender Field", "default": "", "enable": "enable_user_gender_mappings == true" },
                { "id": "value_male", "type": "text", "title": "Field Value - Male", "default": "", "enable": "enable_user_gender_mappings == true" },
                { "id": "value_female", "type": "text", "title": "Field Value - Female", "default": "", "enable": "enable_user_gender_mappings == true" }
              ]
            }
          ]
        },
        {
          "title": "Vehicle Badge Types",
          "columns": [
            {
              "controls": [
                { "id": "enable_vehicle_mappings", "type": "boolean", "title": "Enable Vehicles from Badge Types", "default": false },
                { "id": "vehicle_badge_employee", "type": "boolean", "title": "Employee", "default": false, "enable": "enable_vehicle_mappings == true" },
                { "id": "vehicle_badge_visitor", "type": "boolean", "title": "Visitor", "default": false, "enable": "enable_vehicle_mappings == true" },
                { "id": "vehicle_badge_temporary", "type": "boolean", "title": "Temporary", "default": false, "enable": "enable_vehicle_mappings == true" },
                { "id": "vehicle_badge_vehicle", "type": "boolean", "title": "Vehicle", "default": false, "enable": "enable_vehicle_mappings == true" },
                { "id": "vehicle_lic_plate_field", "type": "text", "title": "License Plate Field", "default": "SSNO", "enable": "enable_vehicle_mappings == true" },
                { "id": "vehicle_id_field", "type": "text", "title": "Vehicle ID Field", "default": "MIDNAME", "enable": "enable_vehicle_mappings == true" },
                { "id": "vehicle_type_field", "type": "text", "title": "Vehicle Type Field", "default": "ADDRESS", "enable": "enable_vehicle_mappings == true" },
                { "id": "vehicle_company_name", "type": "text", "title": "Company Field", "default": "DEPT", "enable": "enable_vehicle_mappings == true" }
              ]
            }
          ]
        },
        {
          "title": "",
          "columns": [
            {
              "controls": [
                {
                  "id": "btn_bar_advanced",
                  "type": "button_bar",
                  "buttons": [
                    { "id": "btn_test_connect_adv", "title": "Test Connect", "onClick": "dm_shared_testConnection" },
                    { "id": "btn_defaults_adv", "title": "Defaults", "onClick": "setDefaults" },
                    { "id": "btn_ok_adv", "title": "OK", "onClick": "dm_shared_save" }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "title": "Custom Mapping",
      "sections": [
        {
          "title": "",
          "columns": [
            {
              "controls": [
                {
                  "id": "custom_mappings",
                  "type": "keyvalue",
                  "title": "",
                  "key_title": "Source Columns",
                  "key_header": "Source Field",
                  "value_title": "Destination Columns",
                  "value_header": "XPressEntry Field",
                  "default": []
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "title": "Badge Custom Mapping",
      "sections": [
        {
          "title": "",
          "columns": [
            {
              "controls": [
                {
                  "id": "customBadgeFields",
                  "type": "keyvalue",
                  "title": "",
                  "key_title": "Source Columns",
                  "key_header": "Source Field",
                  "value_title": "Destination Columns",
                  "value_header": "XPressEntry Field",
                  "default": [
                    { "key": "BDFABC", "value": "badge_field_data_1" }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
