{
  "customSyncTables": ["USERS", "BADGES", "GROUPS", "GROUPS_USERS", "COMPANIES"],
  "tabs": [
    {
      "title": "Sync",
      "sections": [
        {
          "title": "Sync Operations",
          "columns": [
            {
              "controls": [
                {
                  "id": "sync_buttons",
                  "type": "button_bar",
                  "buttons": [
                    {
                      "id": "btn_partial_sync",
                      "title": "Partial Sync Now",
                      "onClick": "dm_shared_runPartialSync",
                      "tooltip": "Pull the latest table changes from the external system. Partial syncs are incremental changes to Users and Badges, if allowed by the external system's API."
                    },
                    {
                      "id": "btn_full_sync",
                      "title": "Full Sync Now",
                      "onClick": "dm_shared_runFullSync",
                      "tooltip": "Pull all records from the external system. Replaces the full local dataset with the current state of the external system."
                    },
                    {
                      "id": "btn_custom_sync",
                      "title": "Custom Sync Now",
                      "onClick": "dm_shared_runCustomSync",
                      "tooltip": "Run a custom sync operation defined by this data manager. Right-click to edit the custom sync tables.",
                      "rightClickMenu": [
                        { "label": "Edit Custom Sync", "onClick": "dm_shared_editCustomSync" }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "Live Log",
          "columns": [
            {
              "controls": [
                { "id": "sync_log", "type": "log_view" }
              ]
            }
          ]
        }
      ]
    },

    {
      "title": "Settings",
      "sections": [
        {
          "title": "Connection",
          "columns": [
            {
              "controls": [
                { "id": "api_url",       "type": "text",     "title": "API URL",       "default": "https://api.cloud-identity.example.com" },
                { "id": "tenant_id",     "type": "text",     "title": "Tenant ID",     "default": "" },
                { "id": "client_id",     "type": "text",     "title": "Client ID",     "default": "" },
                { "id": "client_secret", "type": "password", "title": "Client Secret", "default": "" }
              ]
            }
          ]
        },
        {
          "title": "Options",
          "columns": [
            {
              "controls": [
                { "id": "sync_enabled",  "type": "boolean",        "title": "Enable automatic sync",   "default": true },
                { "id": "sync_interval", "type": "number_spinner", "title": "Sync interval (minutes)", "default": 60,
                  "validations": [{ "type": "min_max", "min": 5, "max": 1440, "error": "5–1440 min" }] },
                { "id": "environment",   "type": "select",         "title": "Environment",
                  "values": [
                    { "text": "Production",  "value": "prod"  },
                    { "text": "Staging",     "value": "stage" },
                    { "text": "Development", "value": "dev"   }
                  ],
                  "default": "prod"
                }
              ]
            }
          ]
        },
        {
          "title": "",
          "columns": [
            {
              "controls": [
                {
                  "id": "btn_bar_settings",
                  "type": "button_bar",
                  "buttons": [
                    { "id": "btn_test_connect", "title": "Test Connect", "onClick": "dm_shared_testConnection" },
                    { "id": "btn_ok",           "title": "OK",           "onClick": "dm_shared_save" }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },

    {
      "title": "Enable → Tab",
      "sections": [
        {
          "title": "Enable on Tab — enables or disables the 'Conditional Tab'",
          "columns": [
            {
              "controls": [
                {
                  "id": "enable_tab_demo",
                  "type": "boolean",
                  "title": "Enable the 'Conditional Tab'",
                  "default": false
                },
                {
                  "id": "enable_tab_note",
                  "type": "text",
                  "title": "Note",
                  "default": "The 'Conditional Tab' has enable: \"enable_tab_demo == true\". Toggle the switch above and the tab will become active.",
                  "enable": false
                }
              ]
            }
          ]
        }
      ]
    },

    {
      "title": "Conditional Tab",
      "enable": "enable_tab_demo == true",
      "sections": [
        {
          "title": "This tab was enabled because enable_tab_demo == true",
          "columns": [
            {
              "controls": [
                {
                  "id": "conditional_tab_field",
                  "type": "text",
                  "title": "Sample field",
                  "default": "Visible because the tab is enabled"
                }
              ]
            }
          ]
        }
      ]
    },

    {
      "title": "Enable → Section & Field",
      "sections": [
        {
          "title": "Enable on Section — enables or disables the section below",
          "columns": [
            {
              "controls": [
                {
                  "id": "enable_section_demo",
                  "type": "boolean",
                  "title": "Enable the 'Section controlled by enable'",
                  "default": false
                }
              ]
            }
          ]
        },
        {
          "title": "Section controlled by enable (enable: \"enable_section_demo == true\")",
          "enable": "enable_section_demo == true",
          "columns": [
            {
              "controls": [
                {
                  "id": "section_enable_field_1",
                  "type": "text",
                  "title": "Field A",
                  "default": "Interactive only when the section is enabled"
                },
                {
                  "id": "section_enable_field_2",
                  "type": "number_spinner",
                  "title": "Field B",
                  "default": 42,
                  "validations": [
                    { "type": "min_max", "min": 0, "max": 9999, "error": "0–9999" }
                  ]
                },
                {
                  "id": "section_enable_field_3",
                  "type": "boolean",
                  "title": "Field C (boolean)",
                  "default": false
                }
              ]
            }
          ]
        },
        {
          "title": "Enable on Field — enables or disables individual fields",
          "columns": [
            {
              "controls": [
                {
                  "id": "enable_fields_demo",
                  "type": "boolean",
                  "title": "Enable the fields below",
                  "default": false
                },
                {
                  "id": "field_enable_text",
                  "type": "text",
                  "title": "Text field (enable: \"enable_fields_demo == true\")",
                  "default": "",
                  "enable": "enable_fields_demo == true"
                },
                {
                  "id": "field_enable_spinner",
                  "type": "number_spinner",
                  "title": "Number field (enable: \"enable_fields_demo == true\")",
                  "default": 100,
                  "validations": [
                    { "type": "min_max", "min": 1, "max": 1000, "error": "1–1000" }
                  ],
                  "enable": "enable_fields_demo == true"
                },
                {
                  "id": "field_enable_select",
                  "type": "select",
                  "title": "Select (enable: \"enable_fields_demo == true\")",
                  "values": [
                    { "text": "Option A", "value": "a" },
                    { "text": "Option B", "value": "b" },
                    { "text": "Option C", "value": "c" }
                  ],
                  "default": "a",
                  "enable": "enable_fields_demo == true"
                }
              ]
            }
          ]
        }
      ]
    },

    {
      "title": "Display → Section & Field",
      "sections": [
        {
          "title": "Display on Section — shows or hides the section below",
          "columns": [
            {
              "controls": [
                {
                  "id": "show_section_demo",
                  "type": "boolean",
                  "title": "Show the 'Section controlled by display'",
                  "default": false
                }
              ]
            }
          ]
        },
        {
          "title": "Section controlled by display (display: \"show_section_demo == true\")",
          "display": "show_section_demo == true",
          "columns": [
            {
              "controls": [
                {
                  "id": "section_display_field_1",
                  "type": "text",
                  "title": "Field A",
                  "default": "Only visible when show_section_demo is true"
                },
                {
                  "id": "section_display_field_2",
                  "type": "boolean",
                  "title": "Field B (boolean)",
                  "default": false
                },
                {
                  "id": "section_display_field_3",
                  "type": "password",
                  "title": "Field C (password)",
                  "default": ""
                }
              ]
            }
          ]
        },
        {
          "title": "Display on Field — shows or hides individual fields",
          "columns": [
            {
              "controls": [
                {
                  "id": "show_fields_demo",
                  "type": "boolean",
                  "title": "Show the fields below",
                  "default": false
                },
                {
                  "id": "field_display_text",
                  "type": "text",
                  "title": "Text field (display: \"show_fields_demo == true\")",
                  "default": "",
                  "display": "show_fields_demo == true"
                },
                {
                  "id": "field_display_select",
                  "type": "select",
                  "title": "Select (display: \"show_fields_demo == true\")",
                  "values": [
                    { "text": "Option X", "value": "x" },
                    { "text": "Option Y", "value": "y" }
                  ],
                  "default": "x",
                  "display": "show_fields_demo == true"
                },
                {
                  "id": "field_display_spinner",
                  "type": "number_spinner",
                  "title": "Number (display: \"show_fields_demo == true\")",
                  "default": 0,
                  "display": "show_fields_demo == true",
                  "validations": [
                    { "type": "min_max", "min": 0, "max": 999, "error": "0–999" }
                  ]
                },
                {
                  "id": "field_display_bool",
                  "type": "boolean",
                  "title": "Boolean (display: \"show_fields_demo == true\")",
                  "default": false,
                  "display": "show_fields_demo == true"
                }
              ]
            }
          ]
        }
      ]
    },

    {
      "title": "2 Columns",
      "sections": [
        {
          "title": "2-column layout — all control types",
          "columns": [
            {
              "controls": [
                { "id": "col2_text",     "type": "text",           "title": "Text",     "default": "sample text value" },
                { "id": "col2_password", "type": "password",       "title": "Password", "default": "" },
                { "id": "col2_number",   "type": "number",         "title": "Number",   "default": 80 },
                { "id": "col2_spinner",  "type": "number_spinner", "title": "Spinner",  "default": 500,
                  "validations": [ { "type": "min_max", "min": 1, "max": 9999, "error": "1–9999" } ] },
                { "id": "col2_boolean",  "type": "boolean",        "title": "Boolean",  "default": true }
              ]
            },
            {
              "controls": [
                {
                  "id": "col2_select",
                  "type": "select",
                  "title": "Select",
                  "values": [
                    { "text": "Option 1", "value": "1" },
                    { "text": "Option 2", "value": "2" },
                    { "text": "Option 3", "value": "3" }
                  ],
                  "default": "1"
                },
                {
                  "id": "col2_radio",
                  "type": "radio",
                  "title": "Radio",
                  "values": [
                    { "text": "Alpha", "value": "alpha" },
                    { "text": "Beta",  "value": "beta"  },
                    { "text": "Gamma", "value": "gamma" }
                  ],
                  "default": "alpha"
                }
              ]
            }
          ]
        },
        {
          "title": "Key-Value — field mapping",
          "columns": [
            {
              "controls": [
                {
                  "id": "demo_mappings",
                  "type": "keyvalue",
                  "title": "",
                  "key_title": "Source Field",
                  "key_header": "Source",
                  "value_title": "Target Field",
                  "value_header": "Target",
                  "default": [
                    { "key": "firstName", "value": "first_name" },
                    { "key": "lastName",  "value": "last_name"  }
                  ]
                }
              ]
            }
          ]
        },
        {
          "title": "",
          "columns": [
            {
              "controls": [
                {
                  "id": "btn_bar_2col",
                  "type": "button_bar",
                  "buttons": [
                    { "id": "btn_test_2col", "title": "Test Connect", "onClick": "dm_shared_testConnection" },
                    { "id": "btn_ok_2col",   "title": "OK",           "onClick": "dm_shared_save" }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
