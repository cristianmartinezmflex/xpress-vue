{
  "tabs": [
    {
      "title": "Basic",
      "columns": [
        {
          "sections": [
            {
              "title": "Connection",
              "controls": [
                {
                  "id": "server_ip",
                  "type": "text",
                  "title": "Server IP",
                  "default": ""
                },
                {
                  "id": "server_port",
                  "type": "number_spinner",
                  "title": "Port",
                  "default": 8000,
                  "validations": [
                    {
                      "type": "required",
                      "error": "Port is required"
                    },
                    {
                      "type": "min_max",
                      "min": 1,
                      "max": 65535,
                      "error": "Port must be between 1 and 65535"
                    }
                  ]
                },
                {
                  "id": "user_name",
                  "type": "text",
                  "title": "User Name",
                  "default": ""
                },
                {
                  "id": "password",
                  "type": "password",
                  "title": "Password",
                  "default": ""
                },
                {
                  "id": "timezoneinfo",
                  "type": "select",
                  "title": "Server Timezone",
                  "values": [
                    {
                      "text": "US Eastern Standard Time",
                      "value": "US Eastern Standard Time"
                    },
                    {
                      "text": "US Central Standard Time",
                      "value": "US Central Standard Time"
                    },
                    {
                      "text": "US Mountain Standard Time",
                      "value": "US Mountain Standard Time"
                    },
                    {
                      "text": "US Pacific Standard Time",
                      "value": "US Pacific Standard Time"
                    },
                    {
                      "text": "UTC",
                      "value": "UTC"
                    }
                  ],
                  "default": "US Mountain Standard Time"
                }
              ]
            },
            {
              "title": "API Settings",
              "controls": [
                {
                  "id": "api_query_size",
                  "type": "number_spinner",
                  "title": "Api Query Size",
                  "default": 500,
                  "validations": [
                    {
                      "type": "required",
                      "error": "Api Query Size is required"
                    },
                    {
                      "type": "min_max",
                      "min": 1,
                      "max": 10000,
                      "error": "Must be between 1 and 10000"
                    }
                  ]
                },
                {
                  "id": "api_delay",
                  "type": "number_spinner",
                  "title": "Delay for API (MS)",
                  "default": 10,
                  "validations": [
                    {
                      "type": "required",
                      "error": "Delay is required"
                    },
                    {
                      "type": "min_max",
                      "min": 0,
                      "max": 60000,
                      "error": "Must be between 0 and 60000"
                    }
                  ]
                },
                {
                  "id": "data_check_interval",
                  "type": "number_spinner",
                  "title": "Data Change Check Interval (s)",
                  "default": 30,
                  "validations": [
                    {
                      "type": "required",
                      "error": "Interval is required"
                    },
                    {
                      "type": "min_max",
                      "min": 1,
                      "max": 3600,
                      "error": "Must be between 1 and 3600"
                    }
                  ]
                }
              ]
            },
            {
              "title": "Options",
              "controls": [
                {
                  "id": "use_ssl",
                  "type": "boolean",
                  "title": "Use SSL",
                  "default": false
                },
                {
                  "id": "create_doors",
                  "type": "boolean",
                  "title": "Create Doors",
                  "default": false
                },
                {
                  "id": "validate_ssl",
                  "type": "boolean",
                  "title": "Validate SSL Cert",
                  "default": false
                },
                {
                  "id": "download_pictures",
                  "type": "boolean",
                  "title": "Download Pictures",
                  "default": true
                },
                {
                  "id": "verbose_api_data",
                  "type": "boolean",
                  "title": "Verbose API Data",
                  "default": false
                },
                {
                  "id": "pull_companies",
                  "type": "boolean",
                  "title": "Pull Customers As Companies",
                  "default": false
                },
                {
                  "id": "ignore_badge_invalidation",
                  "type": "boolean",
                  "title": "Ignore Badge Invalidation",
                  "default": false
                },
                {
                  "id": "compare_user_end_dates",
                  "type": "boolean",
                  "title": "Compare and set User End Date",
                  "default": false
                },
                {
                  "id": "use_enable_cardholder_api",
                  "type": "boolean",
                  "title": "Use API to Enable Cardholder in Galaxy",
                  "default": false
                },
                {
                  "id": "use_reader_timezone",
                  "type": "boolean",
                  "title": "Use Reader Timezone to Send Activity",
                  "default": false
                }
              ]
            },
            {
              "title": "Custom User Mappings",
              "controls": [
                {
                  "id": "user_custom_fields",
                  "type": "keyvalue",
                  "title": "",
                  "key_title": "Source Columns",
                  "key_header": "Source Field",
                  "value_title": "Destination Columns",
                  "value_header": "XPressEntry Field",
                  "default": []
                }
              ]
            },
            {
              "title": "",
              "controls": [
                {
                  "id": "btn_bar_main",
                  "type": "button_bar",
                  "buttons": [
                    {
                      "id": "btn_test_connect",
                      "title": "Test Connect",
                      "onClick": "testConnect"
                    },
                    {
                      "id": "btn_defaults",
                      "title": "Defaults",
                      "onClick": "setDefaults"
                    },
                    {
                      "id": "btn_ok",
                      "title": "OK",
                      "onClick": "save"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
